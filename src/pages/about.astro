---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={`O Nama | ${SITE_TITLE}`} description="Saznajte više o Fazi Elektroinstalacije i kako možemo vam pomoći" />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <div class="hero-copy">
          <p class="eyebrow">O nama</p>
          <h1>Porodična stručnost u elektroinstalacijama</h1>
          <p class="hero-text">
            Faza Elektroinstalacije je tim sa bogatim iskustvom i jasnim ciljem – bezbjedne, moderne i pouzdane instalacije za svaki objekat.
            Radimo sa pažnjom prema detaljima, koristeći samo najbolje materijale i profesionalne pristupe.
          </p>
          <div class="hero-actions">
            <a class="button primary" href="tel:+38761275770">Pozovite nas</a>
            <a class="button secondary" href="mailto:elektroinstalacijefaza@gmail.com">Pošaljite email</a>
          </div>
        </div>

        <div class="hero-stats">
          <div class="stat-card">
            <h3>Porodično iskustvo</h3>
            <p>Decenije prakse u elektroinstalacijama, sa fokusom na povjerenje i dugoročne rezultate.</p>
          </div>
          <div class="stat-card">
            <h3>Profesionalna podrška</h3>
            <p>Od projektovanja do završne provjere, nudimo transparentno vođenje i brzu reakciju.</p>
          </div>
          <div class="stat-card">
            <h3>Sigurnost i kvaliteta</h3>
            <p>Sve instalacije su urađene po važećim standardima, uz preciznu realizaciju i certifikaciju.</p>
          </div>
        </div>
      </section>

      <section class="features">
        <article class="feature-card">
          <h3>Naša filozofija</h3>
          <p>Vjerujemo u direktnu komunikaciju, prilagođena rešenja i poštovanje rokova bez potrebe za kompromisima.</p>
        </article>
        <article class="feature-card">
          <h3>Šta dobijate</h3>
          <p>Jasne procjene, kvalitetne materijale i trajna rješenja koja štede vašu energiju i vrijeme.</p>
        </article>
        <article class="feature-card">
          <h3>Gdje radimo</h3>
          <p>Radimo na projektima stambenih, poslovnih i industrijskih objekata, sa praktičnim rješenjima za svakodnevne potrebe.</p>
        </article>
      </section>

      <section class="cta-card">
        <div>
          <p class="eyebrow">Kontakt</p>
          <h2>Spremni za konsultaciju ili procjenu?</h2>
          <p>Obratite nam se i iskoristite stručnost koja garantuje sigurnost, pouzdanost i urednu izvedbu.</p>
        </div>
        <a class="button primary center" href="/blog">Pogledajte naše projekte</a>
      </section>
    </main>
    <Footer />
  </body>
</html>
